{
  "identifier": "default",
  "description": "Default capability for LENS photo viewer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:read-all",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**/*" }
      ]
    },
    "shell:default",
    "dialog:default",
    "dialog:allow-open"
  ]
}
