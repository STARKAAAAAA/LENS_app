{
  "name": "@STARKAAAAAA/LENS_app",
  "version": "1.7.1",
  "type": "module",
  "main": "electron/main.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "start": "vite build && electron ."
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "concurrently": "^9.0.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^6.4.2",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "exifr": "^7.1.0",
    "p-limit": "^6.0.0",
    "sharp": "^0.34.0",
    "three": "^0.184.0"
  },
  "build": {
    "appId": "com.lens.photo-viewer",
    "productName": "LENS Beta",
    "directories": {
      "output": "electron-dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!src-tauri/**",
      "!src/**"
    ]
  }
}
